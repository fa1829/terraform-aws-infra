# Terraform state — treat like a database, never commit
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Variables file may contain sensitive values
terraform.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# SSH keys
*.pem
*.key
